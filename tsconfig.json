{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "rootDir": "server",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["server/**/*"],
  "ts-node": {
    "files": true
  }
}
